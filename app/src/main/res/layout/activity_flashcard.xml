<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8"
    android:padding="20dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_revert" app:tint="#2C3E50"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvTopicName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Animals &amp; Pets"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"/>

        <TextView
            android:id="@+id/tvProgressCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="1 / 10"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1976D2"/>
    </RelativeLayout>

    <ProgressBar
        android:id="@+id/pbFlashcard"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="20dp"
        android:progress="10"
        android:progressTint="#1976D2"
        android:backgroundTint="#E0E0E0"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardFlashcard"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imgSpeak"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                app:tint="#FF9800"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:id="@+id/tvWordContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dog"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:textAlignment="center"/>

            <TextView
                android:id="@+id/tvWordMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Con chó (Noun)"
                android:textSize="22sp"
                android:textColor="#4CAF50"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:visibility="gone"/> <TextView
            android:id="@+id/tvWordExample"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eg: The dog is barking loudly."
            android:textSize="16sp"
            android:textStyle="italic"
            android:textColor="#7F8C8D"
            android:layout_marginTop="20dp"
            android:textAlignment="center"
            android:visibility="gone"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap card to flip"
        android:textAlignment="center"
        android:textColor="#95A5A6"
        android:layout_marginTop="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnPrevious"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Previous"
            android:textColor="#2C3E50"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="16dp"
            android:layout_marginEnd="10dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="Next"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1976D2"
            app:cornerRadius="16dp"
            android:layout_marginStart="10dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnTakeQuiz"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="Take Quiz Now"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        app:cornerRadius="16dp"
        android:visibility="gone"/> </LinearLayout>